{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Idempotency": {
    "HeaderName": "Idempotency-Key"
  },
  "BankSimulator": {
    "BaseUrl": "http://localhost:8080",
    "TimeoutSeconds": 10,
    "RetryCount": 5,
    "RetryDelayMs": 300,
    "CircuitBreakerMinimumThroughput": 5,
    "CircuitBreakerBreakSeconds": 30
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "MassTransit": {
    "RabbitMq": {
      "Host": "localhost",
      "VirtualHost": "/",
      "Username": "guest",
      "Password": "guest"
    }
  }
}
